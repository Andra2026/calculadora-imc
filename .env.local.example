# Supabase (obrigatório para o app Next.js)
# Crie um projeto em https://supabase.com e copie de Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Opcional: service role só se precisar de operações server-side com privilégios elevados
# SUPABASE_SERVICE_ROLE_KEY=
